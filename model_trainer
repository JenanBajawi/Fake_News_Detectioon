from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
from sklearn.model_selection import cross_val_score, GridSearchCV
import joblib
import os

class ModelPipeline:
    def __init__(self):
        # Initialize the base Logistic Regression model with sufficient iterations for convergence
        self.model = LogisticRegression(max_iter=1000)
        self.tfidf_uni = TfidfVectorizer(stop_words='english', max_df=0.7, min_df=2)   # Unigram (Single words) Configuration
        self.tfidf_bi = TfidfVectorizer(stop_words='english', max_df=0.7, min_df=2, ngram_range=(1,2)) # Bigram (Pairs of words) Configuration

    def run_baseline(self, X_train, y_train):
        """Step 1: Baseline Model using Unigrams"""
        # Fit and transform the training text into numerical vectors (Unigrams)
        X_uni = self.tfidf_uni.fit_transform(X_train)
        # Evaluate model stability using 5-Fold Cross-Validation
        cv_score = cross_val_score(self.model, X_uni, y_train, cv=5, scoring='f1')
        return cv_score.mean()

    def run_improved(self, X_train, y_train):
        """Step 2: Improved Model using Bigrams"""
        # Fit and transform the training text into numerical vectors (Bigrams)
        X_bi = self.tfidf_bi.fit_transform(X_train)
        # Evaluate performance to see if capturing word pairs adds predictive value
        cv_score = cross_val_score(self.model, X_bi, y_train, cv=5, scoring='f1')
        return cv_score.mean()

    def tune_best_model(self, X_train, y_train, use_bigrams=True):
        """Step 3: Hyperparameter tuning for the winning feature set"""
        # Select the winning vectorizer based on previous evaluation phases
        vectorizer = self.tfidf_bi if use_bigrams else self.tfidf_uni
        # Fit the vectorizer on training data to build the final vocabulary
        X_vectors = vectorizer.fit_transform(X_train)
        
        # Define the parameter grid for Logistic Regression (Tuning the 'C' regularization parameter)
        param_grid = {'C': [0.1, 1, 10]}
        grid = GridSearchCV(LogisticRegression(max_iter=1000), param_grid, cv=5, scoring='f1')
        grid.fit(X_vectors, y_train)
        # Return the best estimator found and the fitted vectorizer for future inference
        return grid.best_estimator_, vectorizer
    


def save_model_version(model, vectorizer, version_name):
    """
    Saves the model and its vectorizer in a specific version folder.
    Args:
        model: The trained model object.
        vectorizer: The fitted TF-IDF vectorizer.
        version_name: String like 'v1_baseline' or 'v2_final'.
    """
    # 1. Create the directory structure: models/v1_baseline/
    base_path = os.path.join('models', version_name)
    if not os.path.exists(base_path):
        os.makedirs(base_path)
    
    # 2. Define file paths
    model_path = os.path.join(base_path, f'{version_name}_model.pkl')
    vec_path = os.path.join(base_path, f'{version_name}_vectorizer.pkl')
    
    # 3. Save the files
    joblib.dump(model, model_path)
    joblib.dump(vectorizer, vec_path)
    
    print(f"--- Successfully saved {version_name} artifacts to {base_path} ---")

